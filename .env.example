# انسخ هذا الملف إلى .env للتشغيل المحلي فقط (لا تستخدمه بالإنتاج -
# بالإنتاج القيم تُقرأ من GitHub Secrets تلقائياً، راجع SECRETS.md)

# ═══════════════════════════════════════════════════════════
# مفاتيح Gemini — كل مفتاح مخصص لوظيفة واحدة فقط
# ═══════════════════════════════════════════════════════════
# المفتاح الخفيف: فلترة ترندات + Quality Gate + Embeddings + استبدال كلمات
GEMINI_KEY_LIGHT=
# المفتاح المتقدم: كتابة السكربت + SEO + التشخيص الذاتي
GEMINI_KEY_ADVANCED=
# مفتاح الجوكر: يُستخدم تلقائياً كاحتياط لو أي مفتاح آخر توقف عن العمل
# (كان مخصصاً لتوليد الصور لكن أُلغيت هذه الميزة)
GEMINI_KEY_IMAGE=
# مفتاح الفلتر البصري: التحقق من تطابق الوسائط مع النص (اختياري، يستخدم ADVANCED لو فارغ)
GEMINI_KEY_FILTER=

# ═══════════════════════════════════════════════════════════
# طبقات التحليل البصري الاحتياطية (بالترتيب: Groq ← Puter ← CLIP)
# ═══════════════════════════════════════════════════════════
# Groq: طبقة ثانية — راجع scripts/groq_client.py
GROQ_API_KEY=
# Puter AI: طبقة ثالثة — راجع scripts/puter_client.py
# ⬇️ ضع هنا الإيميل وكلمة المرور لحساب Puter (أنشئ حساب مجاني من puter.com)
PUTER_USERNAME=your-email@example.com
PUTER_PASSWORD=your-password

# ═══════════════════════════════════════════════════════════
# YouTube
# ═══════════════════════════════════════════════════════════
YOUTUBE_SEARCH_API_KEY=
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REFRESH_TOKEN=

# ═══════════════════════════════════════════════════════════
# مصادر الوسائط (صور + فيديوهات)
# ═══════════════════════════════════════════════════════════
PIXABAY_API_KEY=
PEXELS_API_KEY=

# ═══════════════════════════════════════════════════════════
# Google Sheets (قاعدة البيانات)
# ═══════════════════════════════════════════════════════════
GOOGLE_SERVICE_ACCOUNT_JSON=
SPREADSHEET_ID=

# ═══════════════════════════════════════════════════════════
# تليقرام (التنبيهات الفورية)
# ═══════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════════════════════
# GitHub (التشخيص الذاتي)
# ═══════════════════════════════════════════════════════════
GH_PAT=
